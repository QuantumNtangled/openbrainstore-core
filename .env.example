# Cloud setup config -- see CloudSetup.md. (Just want it running locally, no
# public domain or GitHub OAuth? See LocalSetup.md instead; you won't need
# this file at all.)
#
# Copy to `.env` next to docker-compose.example.yml. Never commit the real .env.
# Generate random secrets with:  openssl rand -hex 32

POSTGRES_PASSWORD=change-me-long-random

# A hostname that resolves to this host. Caddy provisions a Let's Encrypt cert
# for it automatically. (No domain? A wildcard-DNS service like sslip.io works:
# <dashed-ip>.sslip.io resolves to that IP with no setup.)
OBS_DOMAIN=memory.example.com

# GitHub OAuth app (Settings -> Developer settings -> OAuth Apps -> New):
#   Homepage URL:  https://<OBS_DOMAIN>
#   Callback URL:  https://<OBS_DOMAIN>/github/callback
OBS_GH_CLIENT_ID=change-me
OBS_GH_CLIENT_SECRET=change-me

# Comma-separated GitHub logins allowed to use this instance (the whole authz policy).
OBS_GITHUB_ALLOWED_USERS=your-github-login

# Uncomment after creating the obs_app role (see CloudSetup.md "Harden:
# enable row-level security") -- until then the app connects as the Postgres
# superuser, which works fine but bypasses RLS as an isolation backstop.
# OBS_PG_USER=obs_app

# Optional: pin an image tag instead of :latest
# OBS_IMAGE=ghcr.io/QuantumNtangled/openbrainstore-core:latest
